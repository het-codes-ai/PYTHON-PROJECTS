import random
import string

def generate_password():
    print("--- 🔐 Password Generator ---")
    
    # 1. Get user input for length
    try:
        length = int(input("Enter the desired password length: "))
    except ValueError:
        print("Please enter a valid number!")
        return

    # 2. Define the 'pool' of characters
    # string.ascii_letters contains a-z and A-Z
    # string.digits contains 0-9
    # string.punctuation contains symbols like !@#$%
    all_chars = string.ascii_letters + string.digits + string.punctuation

    # 3. Randomly pick characters from the pool
    # The 'k' parameter tells it how many characters to grab
    password_list = random.choices(all_chars, k=length)

    # 4. Join the list into a single string and print
    password = "".join(password_list)
    
    print(f"\nYour new password is: {password}")
    print("----------------------------")

# Run the function
generate_password()
